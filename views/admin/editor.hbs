<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{#if post}}Edit Post{{else}}Write Post{{/if}}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div class="admin-nav">
      <h1>{{#if post}}Edit Post{{else}}Write a New Post{{/if}}</h1>
      <div style="display: flex; align-items: center; gap: 1.5rem;">
        <a href="/admin">← Cancel</a>
        <span style="font-size: 0.6rem; color: var(--on-surface-ghost); letter-spacing: 0.04em; text-transform: uppercase;">EDITOR_V.2.4</span>
      </div>
    </div>
  </header>

  <main>
    <form action="{{#if post}}/admin/posts/{{post.id}}{{else}}/admin/posts{{/if}}" method="POST">
      <label>01_TITLE</label>
      <input type="text" name="title" placeholder="Enter post title..." value="{{post.title}}" required>

      <label>02_EXCERPT</label>
      <input type="text" name="excerpt" placeholder="A brief summary of the post..." value="{{post.excerpt}}">

      <label>ADDON_COVER_IMAGE_URL</label>
      <input type="text" name="coverImage" placeholder="https://example.com/image.jpg..." value="{{post.coverImage}}">

      <label>03_CONTENT_BLOCK</label>
      <textarea name="content" placeholder="Write your thoughts..." style="min-height: 400px;" required>{{post.content}}</textarea>

      <label>04_METADATA_TAGS</label>
      <input type="text" name="tags" placeholder="tech, nestjs, learning" value="{{post.tags}}">

      <div class="publish-toggle">
        <label>
          <input type="checkbox" name="published" {{#if post.published}}checked{{/if}}>
          PUBLISH_STATUS — Make this post visible to readers
        </label>
      </div>

      <button type="submit" class="btn-arrow" style="margin-top: 0.5rem;">{{#if post}}UPDATE POST{{else}}SAVE POST{{/if}}</button>
    </form>
  </main>
</body>
</html>
