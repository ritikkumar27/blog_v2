<!DOCTYPE html>
<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Admin Dashboard</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "on-tertiary": "#ffffff",
                    "primary-fixed-dim": "#c8c6c5",
                    "outline-variant": "#c4c7c7",
                    "on-surface-variant": "#444748",
                    "tertiary": "#0d0a06",
                    "surface-container": "#f4eedb",
                    "tertiary-fixed": "#eae1d7",
                    "on-secondary": "#ffffff",
                    "inverse-surface": "#333124",
                    "on-tertiary-container": "#8e887f",
                    "surface-tint": "#5f5e5e",
                    "secondary-container": "#eeddc6",
                    "surface-container-highest": "#e8e2d0",
                    "surface-bright": "#fff9ea",
                    "outline": "#747878",
                    "on-secondary-fixed-variant": "#504534",
                    "on-tertiary-fixed-variant": "#4b463f",
                    "primary": "#0a0a0a",
                    "on-secondary-container": "#6c614f",
                    "error-container": "#ffdad6",
                    "secondary-fixed": "#f0e0c9",
                    "background": "#fff9ea",
                    "surface-container-lowest": "#ffffff",
                    "primary-fixed": "#e5e2e1",
                    "primary-container": "#212121",
                    "on-primary-container": "#898888",
                    "on-secondary-fixed": "#221a0c",
                    "surface": "#fff9ea",
                    "surface-container-low": "#faf3e1",
                    "secondary-fixed-dim": "#d4c4ae",
                    "on-surface": "#1e1c11",
                    "surface-container-high": "#eee8d6",
                    "on-error": "#ffffff",
                    "on-primary-fixed-variant": "#474746",
                    "on-background": "#1e1c11",
                    "tertiary-container": "#25211b",
                    "secondary": "#685d4b",
                    "on-error-container": "#93000a",
                    "on-tertiary-fixed": "#1f1b15",
                    "inverse-on-surface": "#f7f0de",
                    "tertiary-fixed-dim": "#cdc5bc",
                    "inverse-primary": "#c8c6c5",
                    "surface-variant": "#e8e2d0",
                    "error": "#ba1a1a",
                    "surface-dim": "#e0dac8",
                    "on-primary-fixed": "#1b1c1c",
                    "on-primary": "#ffffff"
            },
            "borderRadius": {
                    "DEFAULT": "0px",
                    "lg": "0px",
                    "xl": "0px",
                    "full": "9999px"
            },
            "fontFamily": {
                    "headline": ["Space Grotesk"],
                    "body": ["Space Grotesk"],
                    "label": ["Space Grotesk"]
            }
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        body {
            font-family: 'Space Grotesk', sans-serif;
        }
        .archival-grid {
            background-image: radial-gradient(circle, rgba(104, 93, 75, 0.2) 1px, transparent 1px);
            background-size: 32px 32px;
            background-position: -16px -16px;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-surface text-on-surface archival-grid min-h-screen">
<!-- NavigationDrawer (Semantic Shell - Left Anchor) -->
<aside class="fixed inset-y-0 left-0 z-50 flex flex-col bg-[#e8e2d0] text-[#0a0a0a] h-full w-72 transition-all duration-200 ease-in-out shadow-xl hidden md:flex">
<div class="p-8 flex items-center gap-3">
<span class="material-symbols-outlined text-2xl">terminal</span>
<h1 class="text-lg font-black tracking-widest uppercase">ADMIN_ARCHIVE</h1>
</div>
<nav class="flex-1 mt-4">
<!-- Active State: Dashboard -->
<a class="flex items-center gap-4 px-8 py-4 bg-[#0a0a0a] text-[#fff9ea] font-['Space_Grotesk'] uppercase text-xs tracking-widest transition-all duration-200" href="/admin">
<span class="material-symbols-outlined">dashboard</span>
<span>Dashboard</span>
</a>
<a class="flex items-center gap-4 px-8 py-4 text-[#685d4b] font-['Space_Grotesk'] uppercase text-xs tracking-widest hover:bg-[#faf3e1] transition-all duration-200" href="/admin">
<span class="material-symbols-outlined">edit_note</span>
<span>Drafts</span>
</a>
<a class="flex items-center gap-4 px-8 py-4 text-[#685d4b] font-['Space_Grotesk'] uppercase text-xs tracking-widest hover:bg-[#faf3e1] transition-all duration-200" href="/admin">
<span class="material-symbols-outlined">query_stats</span>
<span>Analytics</span>
</a>
</nav>
<div class="p-8 mt-auto border-t border-[#685d4b]/10">
<div class="flex items-center gap-3">
<div class="w-10 h-10 bg-primary-container flex items-center justify-center">
<span class="text-[#fff9ea] text-xs font-bold">RK</span>
</div>
<div>
<p class="text-xs font-bold">RITIK KUMAR</p>
<p class="text-[10px] text-[#685d4b]">ROOT_ACCESS</p>
</div>
</div>
</div>
</aside>
<!-- Main Content Canvas -->
<main class="md:ml-72 min-h-screen flex flex-col">
<!-- TopAppBar (Execution from JSON) -->
<header class="bg-[#fff9ea] text-[#0a0a0a] font-['Space_Grotesk'] tracking-tight flex justify-between items-center w-full px-6 py-4 max-w-screen-2xl mx-auto sticky top-0 z-40">
<div class="flex items-center gap-4">
<span class="material-symbols-outlined">terminal</span>
<span class="text-xl font-bold font-['Space_Grotesk'] text-[#0a0a0a]"># blog.ritikkumar.dev</span>
</div>
<div class="flex items-center gap-6">
<a class="text-sm font-medium hover:bg-[#e8e2d0] px-3 py-1 transition-colors duration-150" href="/">← View Site</a>
<a href="/admin/posts/new">
<button class="bg-[#0a0a0a] text-[#fff9ea] px-4 py-2 flex items-center gap-2 hover:bg-primary-container transition-transform active:scale-[0.99] font-medium">
<span class="material-symbols-outlined text-sm">add</span>
<span>New Post</span>
</button>
</a>
<span class="material-symbols-outlined cursor-pointer hover:bg-[#e8e2d0] p-1">menu</span>
</div>
</header>
<!-- Content Body -->
<div class="p-8 lg:p-12 space-y-12">
<!-- Dashboard Title & Stats (Asymmetric Layout) -->
<section class="grid grid-cols-1 lg:grid-cols-12 gap-8">
<div class="lg:col-span-8">
<h2 class="text-5xl font-extrabold tracking-tighter mb-2">Dashboard</h2>
<p class="text-secondary font-mono text-sm">COMPILED_ON: 2024 // SYSTEM_READY</p>
</div>
<div class="lg:col-span-4 grid grid-cols-2 gap-4">
<div class="bg-surface-container-highest p-6 space-y-2">
<p class="text-[10px] font-black uppercase tracking-widest text-secondary">Total Views</p>
<p class="text-3xl font-bold" id="totalViews">—</p>
<div class="h-1 bg-primary w-full mt-2"></div>
</div>
<div class="bg-surface-container-highest p-6 space-y-2">
<p class="text-[10px] font-black uppercase tracking-widest text-secondary">Total Likes</p>
<p class="text-3xl font-bold" id="totalLikes">—</p>
<div class="h-1 bg-primary w-1/3 mt-2"></div>
</div>
</div>
</section>
<!-- Bento Layout for Comments and Posts -->
<div class="grid grid-cols-1 xl:grid-cols-12 gap-8">
<!-- Recent Comments Section (6 cols) -->
<section class="xl:col-span-6 space-y-6">
<div class="flex justify-between items-end border-b border-outline-variant/30 pb-4">
<h3 class="text-xl font-bold tracking-tight">Recent Comments</h3>
<a class="text-xs uppercase font-bold tracking-widest hover:underline underline-offset-4" href="#">View All</a>
</div>
<div class="space-y-4">

{{#if pendingComments.length}}
  {{#each pendingComments}}
    <div class="group bg-surface-container-low border-l-4 border-blue-600 p-6 transition-all hover:bg-surface-container-high">
    <div class="flex justify-between items-start mb-4">
    <div class="flex items-center gap-3">
    <div class="w-8 h-8 bg-[#0a0a0a] flex items-center justify-center">
    <span class="text-[10px] text-white">#</span>
    </div>
    <div>
    <p class="text-sm font-bold">{{this.authorName}}</p>
    <p class="text-[10px] text-secondary font-mono uppercase">On Post #{{this.postId}}</p>
    </div>
    </div>
    <button onclick="deleteComment({{this.id}})" class="text-error opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-1 text-[10px] font-bold uppercase tracking-widest">
    <span class="material-symbols-outlined text-xs">delete</span>
                                        Delete
                                    </button>
    </div>
    <p class="text-sm leading-relaxed text-on-surface-variant">
                                    "{{this.body}}"
                                </p>
    </div>
  {{/each}}
{{else}}
  <p class="empty-state">// No comments in the archive.</p>
{{/if}}

</div>
</section>
<!-- Your Posts Section (6 cols) -->
<section class="xl:col-span-6 space-y-6">
<div class="flex justify-between items-end border-b border-outline-variant/30 pb-4">
<h3 class="text-xl font-bold tracking-tight">Your Posts</h3>
<div class="flex gap-4">
<span class="text-[10px] font-mono text-secondary">Total: {{posts.length}}</span>
<a class="text-xs uppercase font-bold tracking-widest hover:underline underline-offset-4" href="#">Manage</a>
</div>
</div>
<div class="divide-y divide-outline-variant/20">

{{#if posts.length}}
  {{#each posts}}
    <div class="py-5 flex items-center justify-between group">
    <div class="space-y-1">
    <div class="flex items-center gap-3">
    <h4 class="font-bold text-md"><a href="/admin/posts/{{this.id}}/edit">{{this.title}}</a></h4>
    {{#if this.published}}
      <span class="bg-secondary text-[#fff9ea] text-[10px] px-2 py-0.5 font-mono uppercase tracking-tighter">Published</span>
    {{else}}
      <span class="bg-surface-variant text-on-surface-variant text-[10px] px-2 py-0.5 font-mono uppercase tracking-tighter">Draft</span>
    {{/if}}
    </div>
    <p class="text-xs text-secondary posts-meta-data" data-views="{{this.views}}" data-likes="{{this.likes}}">{{formatDate this.createdAt}} • {{this.views}} views • {{this.likes}} likes</p>
    </div>
    <div class="flex items-center gap-5">
    <a class="text-[10px] font-black uppercase tracking-widest flex items-center gap-1 hover:text-primary transition-colors" href="/admin/posts/{{this.id}}/edit">
    <span class="material-symbols-outlined text-xs">edit</span>
                                        Edit
                                    </a>
    <button onclick="deletePost({{this.id}})" class="text-[10px] text-error font-black uppercase tracking-widest flex items-center gap-1 hover:text-red-700 transition-colors opacity-0 group-hover:opacity-100">
    <span class="material-symbols-outlined text-xs">delete</span>
                                        Delete
                                    </button>
    <a href="/p/{{this.slug}}">
    <span class="material-symbols-outlined text-secondary text-sm cursor-pointer hover:text-primary">open_in_new</span>
    </a>
    </div>
    </div>
  {{/each}}
{{else}}
  <p class="empty-state">// No entries compiled yet.</p>
{{/if}}

</div>
<!-- Decorative Archival Element -->
<div class="mt-8 p-12 bg-surface-container-low flex flex-col items-center justify-center text-center space-y-4 border border-dashed border-outline-variant">
<span class="material-symbols-outlined text-4xl text-secondary">book_5</span>
<div>
<p class="text-xs font-bold uppercase tracking-[0.2em]">Archival Codex</p>
<p class="text-[10px] text-secondary max-w-xs mt-2">Every entry is a permanent record in the digital archive. Curate with intentionality.</p>
</div>
</div>
</section>
</div>
<!-- Footer (Execution from JSON) -->
<footer class="bg-[#fff9ea] text-[#685d4b] font-['Space_Grotesk'] text-sm w-full flex flex-col md:flex-row justify-between items-center px-8 py-12 border-t-0 mt-auto bg-[#faf3e1]">
<div class="flex items-center gap-4 mb-4 md:mb-0">
<span class="font-bold text-[#0a0a0a]">© 2026 COMPILED_ARCHIVE</span>
</div>
<div class="flex gap-8">
<a class="text-[#685d4b] hover:text-[#0a0a0a] transition-colors duration-150 hover:underline" href="https://github.com/ritikkumar27">Github</a>
<a class="text-[#685d4b] hover:text-[#0a0a0a] transition-colors duration-150 hover:underline" href="https://ritikkumar.dev">Portfolio</a>
</div>
</footer>
</div>
</main>
<!-- Contextual FAB - Only for main actions like New Post -->
<a href="/admin/posts/new">
<button class="md:hidden fixed bottom-8 right-8 bg-[#0a0a0a] text-[#fff9ea] w-14 h-14 shadow-2xl flex items-center justify-center transition-transform active:scale-95">
<span class="material-symbols-outlined">add</span>
</button>
</a>
  <script>
    // Calculate totals from rendered post data
    (function() {
      const rows = document.querySelectorAll('.posts-meta-data');
      let totalViews = 0, totalLikes = 0;
      rows.forEach(row => {
        totalViews += parseInt(row.getAttribute('data-views') || 0);
        totalLikes += parseInt(row.getAttribute('data-likes') || 0);
      });
      const ve = document.getElementById('totalViews');
      const le = document.getElementById('totalLikes');
      if (ve) ve.textContent = totalViews.toLocaleString();
      if (le) le.textContent = totalLikes.toLocaleString();
    })();

    async function deleteComment(id) {
      if (!confirm('Permanently delete this comment?')) return;
      const res = await fetch(`/api/comments/${id}`, { method: 'DELETE' });
      if (res.ok) window.location.reload();
    }

    async function deletePost(id) {
      if (!confirm('Permanently delete this post and ALL its comments? This cannot be undone.')) return;
      const res = await fetch(`/admin/posts/${id}`, { method: 'DELETE' });
      if (res.ok) window.location.reload();
    }
  </script>
</body></html>
