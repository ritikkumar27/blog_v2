<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div class="admin-nav">
      <h1>Dashboard</h1>
      <div>
        <a href="/" style="margin-right: 1.5rem;">← View Site</a>
        <a href="/admin/posts/new"><button>[+ New Post]</button></a>
      </div>
    </div>
  </header>

  <main>
    <h2>Your Posts</h2>
    {{#if posts.length}}
      {{#each posts}}
        <div class="post-card" style="display: flex; justify-content: space-between; align-items: center;">
          <div>
            <h3 style="margin: 0; font-size: 1.1rem;"><a href="/admin/posts/{{this.id}}/edit">{{this.title}}</a></h3>
            <p class="meta" style="margin-top: 0.5rem;">{{#if this.published}}[Published]{{else}}[Draft]{{/if}} &bull; {{this.views}} views</p>
          </div>
        </div>
      {{/each}}
    {{else}}
      <p>> No posts yet. Time to write.</p>
    {{/if}}
  </main>
</body>
</html>
