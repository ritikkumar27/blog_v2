<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div class="admin-nav">
      <h1>Dashboard</h1>
      <div>
        <a href="/" style="margin-right: 1.5rem;">← View Site</a>
        <a href="/admin/posts/new"><button>[+ New Post]</button></a>
      </div>
    </div>
  </header>

  <main>
    <h2>Recent Comments (Live)</h2>
    {{#if pendingComments.length}}
      <div style="margin-bottom: 3rem;">
        {{#each pendingComments}}
          <div class="post-card" style="padding: 1rem; border-left: 4px solid #3498db; margin-bottom: 1rem;">
            <p style="margin: 0 0 0.5rem 0;"><strong>{{this.authorName}}</strong> commented on post #{{this.postId}}:</p>
            <p style="margin: 0 0 1rem 0; color: #555;">"{{this.body}}"</p>
            
            <button onclick="deleteComment({{this.id}})" style="background: #e74c3c; padding: 0.5rem 1rem; font-size: 0.9rem;">Delete</button>
          </div>
        {{/each}}
      </div>
    {{else}}
      <p style="color: #666; margin-bottom: 3rem;">No comments yet.</p>
    {{/if}}

    <hr style="margin: 3rem 0; border: 0; border-top: 1px solid #eaeaea;">

    <h2>Your Posts</h2>
    {{#if posts.length}}
      {{#each posts}}
        <div class="post-card" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
          <div>
            <h3 style="margin: 0; font-size: 1.1rem;"><a href="/admin/posts/{{this.id}}/edit">{{this.title}}</a></h3>
            <p class="meta" style="margin-top: 0.5rem;">{{#if this.published}}[Published]{{else}}[Draft]{{/if}} &bull; {{this.views}} views</p>
          </div>
        </div>
      {{/each}}
    {{else}}
      <p>> No posts yet. Time to write.</p>
    {{/if}}
  </main>

  <script>
    async function deleteComment(id) {
      if (!confirm('Permanently delete this comment?')) return;
      
      const res = await fetch(`/api/comments/${id}`, { method: 'DELETE' });
      if (res.ok) window.location.reload();
    }
  </script>
</body>
</html>
