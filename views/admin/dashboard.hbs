<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div class="admin-nav">
      <h1>ADMIN_ARCHIVE</h1>
      <div style="display: flex; align-items: center; gap: 1.5rem;">
        <a href="/">← View Site</a>
        <a href="/admin/posts/new"><button style="padding: 0.5rem 1rem; font-size: 0.72rem;">+ NEW POST</button></a>
      </div>
    </div>
  </header>

  <main>
    <h1 class="dashboard-title">Dashboard</h1>
    <p class="dashboard-subtitle">COMPILED_ON: 2024 // SYSTEM_READY</p>

    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-box">
        <p class="stat-label">Total Views</p>
        <p class="stat-value" id="totalViews">—</p>
      </div>
      <div class="stat-box">
        <p class="stat-label">Total Likes</p>
        <p class="stat-value" id="totalLikes">—</p>
      </div>
    </div>

    <!-- Recent Comments -->
    <div class="section-header-row">
      <h2 class="section-heading">Recent Comments</h2>
      <span class="section-link">VIEW ALL</span>
    </div>

    {{#if pendingComments.length}}
      <div style="margin-bottom: 2.5rem;">
        {{#each pendingComments}}
          <div class="admin-comment-card">
            <p class="commenter-name">{{this.authorName}}</p>
            <p class="commenter-context">ON POST #{{this.postId}}</p>
            <p class="comment-quote">{{this.body}}</p>
            <button class="btn-danger" onclick="deleteComment({{this.id}})">DELETE</button>
          </div>
        {{/each}}
      </div>
    {{else}}
      <p class="empty-state">// No comments in the archive.</p>
    {{/if}}

    <hr class="divider">

    <!-- Posts -->
    <div class="section-header-row">
      <h2 class="section-heading">Your Posts</h2>
      <span class="section-link">MANAGE</span>
    </div>

    {{#if posts.length}}
      {{#each posts}}
        <div class="admin-post-row">
          <div>
            <h3><a href="/admin/posts/{{this.id}}/edit">{{this.title}}</a></h3>
            <p class="meta">
              {{#if this.published}}<span class="badge badge-published">PUBLISHED</span>{{else}}<span class="badge badge-draft">DRAFT</span>{{/if}}
              &bull; {{this.views}} views &bull; {{this.likes}} likes
            </p>
          </div>
          <a href="/admin/posts/{{this.id}}/edit" class="edit-link">EDIT</a>
        </div>
      {{/each}}
    {{else}}
      <p class="empty-state">// No entries compiled yet.</p>
    {{/if}}
  </main>

  <footer class="site-footer">
    <p>Archival Codex — Every entry is a permanent record in the digital archive.</p>
  </footer>

  <script>
    // Calculate totals from rendered post data
    (function() {
      const rows = document.querySelectorAll('.admin-post-row .meta');
      let totalViews = 0, totalLikes = 0;
      rows.forEach(row => {
        const text = row.textContent;
        const v = text.match(/(\d+)\s*views/);
        const l = text.match(/(\d+)\s*likes/);
        if (v) totalViews += parseInt(v[1]);
        if (l) totalLikes += parseInt(l[1]);
      });
      const ve = document.getElementById('totalViews');
      const le = document.getElementById('totalLikes');
      if (ve) ve.textContent = totalViews.toLocaleString();
      if (le) le.textContent = totalLikes.toLocaleString();
    })();

    async function deleteComment(id) {
      if (!confirm('Permanently delete this comment?')) return;
      const res = await fetch(`/api/comments/${id}`, { method: 'DELETE' });
      if (res.ok) window.location.reload();
    }
  </script>
</body>
</html>
