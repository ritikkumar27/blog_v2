<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{post.title}} | Ritik Kumar</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div id="progressBar" style="position: fixed; top: 0; left: 0; height: 4px; background: #111; width: 0%; z-index: 9999; transition: width 0.1s ease-out;"></div>
  <header>
    <nav><a href="/">← Back to Home</a></nav>
  </header>

  <main>
    <h1>{{post.title}}</h1>
    <p class="meta">Published: {{formatDate post.createdAt}} • {{readingTime post.content}} • {{post.views}} views</p>
    
    <div class="content">
      {{{markdown post.content}}}
    </div>

    <!-- Upvote Section -->
    <div style="margin-top: 2rem; display: flex; align-items: center; gap: 0.5rem;">
      <button id="likeBtn" style="background: none; border: 1px solid #ccc; padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer; display: flex; align-items: center; gap: 0.4rem; transition: all 0.2s; color: #444; font-weight: bold;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 19V5M5 12l7-7 7 7"/>
        </svg>
        Upvote
      </button>
      <span style="font-weight: bold; font-size: 1.1rem; color: #444;" id="likeCount">{{post.likes}}</span>
      
      <button id="copyBtn" style="background: none; border: 1px solid #ccc; padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer; display: flex; align-items: center; gap: 0.4rem; transition: all 0.2s; color: #444; font-weight: bold; margin-left: 1rem;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <span id="copyBtnText">Copy Link</span>
      </button>
    </div>

    <hr style="margin: 3rem 0; border: 0; border-top: 1px solid #eaeaea;">

    <!-- --- COMMENT SECTION --- -->
    <section id="comments">
      <h3 id="commentCountHeader">Comments</h3>
      
      <form id="commentForm" style="margin-bottom: 2rem;">
        <input type="hidden" id="postId" value="{{post.id}}">
        <input type="text" id="authorName" placeholder="Your name" required style="width: 100%; padding: 0.8rem; margin-bottom: 1rem; border: 1px solid #ddd; border-radius: 6px;">
        <textarea id="commentBody" placeholder="Write a comment..." style="width: 100%; min-height: 100px; padding: 0.8rem; margin-bottom: 1rem; border: 1px solid #ddd; border-radius: 6px; font-family: inherit; resize: vertical;" required></textarea>
        <!-- Frontend Validation: 'required' tags block empty submissions -->
        <button type="submit" style="background: #111; color: white; border: none; padding: 0.8rem 1.5rem; border-radius: 6px; cursor: pointer;">Post Comment</button>
      </form>

      <div id="commentList">
        <p style="color: #888;">Loading comments...</p>
      </div>
    </section>
  </main>

  <script>
    const postId = document.getElementById('postId').value;

    // Helper: Convert timestamp to relative time (e.g. "2 hours ago")
    function timeAgo(dateString) {
      if (!dateString) return '';
      const seconds = Math.floor((new Date() - new Date(dateString)) / 1000);
      let interval = seconds / 31536000;
      if (interval > 1) return Math.floor(interval) + " years ago";
      interval = seconds / 2592000;
      if (interval > 1) return Math.floor(interval) + " months ago";
      interval = seconds / 86400;
      if (interval > 1) return Math.floor(interval) + " days ago";
      interval = seconds / 3600;
      if (interval > 1) return Math.floor(interval) + " hours ago";
      interval = seconds / 60;
      if (interval > 1) return Math.floor(interval) + " minutes ago";
      return Math.floor(seconds) + " seconds ago";
    }
    
    // 1. Fetch Comments & Count
    async function loadComments() {
      const res = await fetch(`/api/comments/${postId}`);
      if (!res.ok) return;
      const comments = await res.json();
      
      const countHeader = document.getElementById('commentCountHeader');
      const list = document.getElementById('commentList');
      
      // Update the count header dynamically
      countHeader.innerText = `${comments.length} Comment${comments.length !== 1 ? 's' : ''}`;
      
      if (comments.length === 0) {
        list.innerHTML = '<p style="color: #888; font-style: italic;">No comments yet. Be the first to share your thoughts!</p>';
        return;
      }

      list.innerHTML = comments.map(c => `
        <div style="background: white; padding: 1.5rem; border-radius: 8px; border: 1px solid #eaeaea; margin-bottom: 1rem;">
          <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 0.5rem;">
            <strong style="font-size: 1.1rem; color: #111;">${c.authorName}</strong>
            <small style="color: #888;">${timeAgo(c.createdAt)}</small>
          </div>
          <p style="margin: 0; color: #333; line-height: 1.5; white-space: pre-wrap;">${c.body}</p>
        </div>
      `).join('');
    }

    // 2. Submit New Comment (Instant Publish)
    document.getElementById('commentForm').onsubmit = async (e) => {
      e.preventDefault();
      const nameInput = document.getElementById('authorName');
      const bodyInput = document.getElementById('commentBody');

      if (!nameInput.value.trim() || !bodyInput.value.trim()) return;

      const res = await fetch('/api/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ postId, authorName: nameInput.value, body: bodyInput.value })
      });

      if (res.ok) {
        document.getElementById('commentForm').reset();
        loadComments(); // Instantly reload to show the newest at the top!
      }
    };

    // Handle Upvote Button
    const likeBtn = document.getElementById('likeBtn');
    let hasLiked = false;
    likeBtn.onclick = async () => {
      if (hasLiked) return;
      hasLiked = true;
      
      // Reddit-style orange active state
      likeBtn.style.color = '#ff4500';
      likeBtn.style.borderColor = '#ff4500';
      likeBtn.style.background = '#fff3f0';
      
      const countSpan = document.getElementById('likeCount');
      countSpan.innerText = parseInt(countSpan.innerText) + 1;
      countSpan.style.color = '#ff4500';

      await fetch(`/api/posts/${postId}/like`, { method: 'POST' });
    };

    // Track View
    fetch(`/api/posts/${postId}/view`, { method: 'POST' });
    loadComments();

    // Copy Link Button
    const copyBtn = document.getElementById('copyBtn');
    const copyBtnText = document.getElementById('copyBtnText');
    if (copyBtn) {
      copyBtn.onclick = async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          copyBtnText.innerText = 'Copied!';
          copyBtn.style.color = '#10b981';
          copyBtn.style.borderColor = '#10b981';
          setTimeout(() => {
            copyBtnText.innerText = 'Copy Link';
            copyBtn.style.color = '#444';
            copyBtn.style.borderColor = '#ccc';
          }, 2000);
        } catch (err) {
          console.error('Failed to copy', err);
        }
      };
    }

    // Scroll Progress Bar
    window.addEventListener('scroll', () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      document.getElementById('progressBar').style.width = scrolled + '%';
    });
  </script>
</body>
</html>
