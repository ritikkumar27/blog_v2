<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{post.title}} | Ritik Kumar</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div id="progressBar" style="position: fixed; top: 0; left: 0; height: 4px; background: linear-gradient(90deg, var(--primary), var(--primary-container)); width: 0%; z-index: 9999; transition: width 0.1s ease-out;"></div>

  <header>
    <nav><a href="/">← Back to Home</a></nav>
  </header>

  <main>
    <div class="metadata-gutter">
      <div class="gutter-item">
        <span class="gutter-label">Published</span>
        <span class="gutter-value">{{formatDate post.createdAt}}</span>
      </div>
      <div class="gutter-item">
        <span class="gutter-label">Status</span>
        <span class="gutter-value">TENDED</span>
      </div>
      <div class="gutter-item">
        <span class="gutter-label">Reading</span>
        <span class="gutter-value">{{readingTime post.content}}</span>
      </div>
    </div>

    <h1>{{post.title}}</h1>

    <p class="post-author"><strong>Ritik Kumar</strong> · Aspiring DevOps Engineer</p>
    <p class="meta">{{post.views}} views</p>

    <div class="content">
      {{{markdown post.content}}}
    </div>

    <!-- Actions -->
    <div style="margin-top: 2.5rem; display: flex; align-items: center; gap: 0.75rem;">
      <button id="likeBtn" class="btn-ghost">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 19V5M5 12l7-7 7 7"/>
        </svg>
        <span id="likeCount">{{post.likes}}</span>
      </button>

      <button id="copyBtn" class="btn-ghost">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="0" ry="0"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <span id="copyBtnText">SHARE</span>
      </button>
    </div>

    <hr class="divider">

    <!-- COMMENTS_ARCHIVE -->
    <section id="comments">
      <h3 class="section-heading" id="commentCountHeader">COMMENTS_ARCHIVE</h3>

      <form id="commentForm" style="margin-bottom: 2rem;">
        <input type="hidden" id="postId" value="{{post.id}}">
        <label>YOUR_NAME</label>
        <input type="text" id="authorName" placeholder="Your name" required>
        <label>COMMENT_BODY</label>
        <textarea id="commentBody" placeholder="Leave your thoughts..." style="min-height: 100px;" required></textarea>
        <button type="submit">POST COMMENT</button>
      </form>

      <div id="commentList">
        <p class="empty-state">Loading archive...</p>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <a href="https://github.com/ritikkumar27">Github</a>
    <a href="https://ritikkumar.dev">Portfolio</a>
  </footer>

  <script>
    const postId = document.getElementById('postId').value;

    function timeAgo(dateString) {
      if (!dateString) return '';
      const seconds = Math.floor((new Date() - new Date(dateString)) / 1000);
      let interval = seconds / 31536000;
      if (interval > 1) return Math.floor(interval) + " years ago";
      interval = seconds / 2592000;
      if (interval > 1) return Math.floor(interval) + " months ago";
      interval = seconds / 86400;
      if (interval > 1) return Math.floor(interval) + " days ago";
      interval = seconds / 3600;
      if (interval > 1) return Math.floor(interval) + " hours ago";
      interval = seconds / 60;
      if (interval > 1) return Math.floor(interval) + " minutes ago";
      return Math.floor(seconds) + " seconds ago";
    }

    async function loadComments() {
      const res = await fetch(`/api/comments/${postId}`);
      if (!res.ok) return;
      const comments = await res.json();

      const countHeader = document.getElementById('commentCountHeader');
      const list = document.getElementById('commentList');

      countHeader.innerText = `COMMENTS_ARCHIVE // ${comments.length} ${comments.length !== 1 ? 'entries' : 'entry'}`;

      if (comments.length === 0) {
        list.innerHTML = '<p class="empty-state">// No entries in comments archive.</p>';
        return;
      }

      list.innerHTML = comments.map(c => `
        <div class="comment-card">
          <div class="comment-header">
            <strong class="comment-author">${c.authorName}</strong>
            <small class="comment-time">${timeAgo(c.createdAt)}</small>
          </div>
          <p class="comment-body">${c.body}</p>
        </div>
      `).join('');
    }

    document.getElementById('commentForm').onsubmit = async (e) => {
      e.preventDefault();
      const nameInput = document.getElementById('authorName');
      const bodyInput = document.getElementById('commentBody');

      if (!nameInput.value.trim() || !bodyInput.value.trim()) return;

      const res = await fetch('/api/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ postId, authorName: nameInput.value, body: bodyInput.value })
      });

      if (res.ok) {
        document.getElementById('commentForm').reset();
        loadComments();
      }
    };

    const likeBtn = document.getElementById('likeBtn');
    let hasLiked = false;
    likeBtn.onclick = async () => {
      if (hasLiked) return;
      hasLiked = true;

      likeBtn.classList.add('active');

      const countSpan = document.getElementById('likeCount');
      countSpan.innerText = parseInt(countSpan.innerText) + 1;

      await fetch(`/api/posts/${postId}/like`, { method: 'POST' });
    };

    fetch(`/api/posts/${postId}/view`, { method: 'POST' });
    loadComments();

    const copyBtn = document.getElementById('copyBtn');
    const copyBtnText = document.getElementById('copyBtnText');
    if (copyBtn) {
      copyBtn.onclick = async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          copyBtnText.innerText = 'COPIED';
          copyBtn.classList.add('active');
          setTimeout(() => {
            copyBtnText.innerText = 'COPY';
            copyBtn.classList.remove('active');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy', err);
        }
      };
    }

    window.addEventListener('scroll', () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      document.getElementById('progressBar').style.width = scrolled + '%';
    });
  </script>
</body>
</html>
